# DevFlow Backend

FLASK_DEBUG=true
PORT=5000

# Authentication
JWT_SECRET_KEY=devflow-super-secret-key-change-in-prod
JWT_EXPIRY_HOURS=24

# Database
DATABASE_URL=sqlite:///../database/app.db

# Token Encryption
TOKEN_ENCRYPTION_KEY=devflow-default-enc-key

# GitHub Integration
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Future Integrations (optional - leave empty until needed)
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=
DOCKER_HUB_USERNAME=
DOCKER_HUB_TOKEN=
KUBE_CONFIG_PATH=
PROMETHEUS_URL=
GRAFANA_URL=
GRAFANA_API_KEY=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
SLACK_WEBHOOK_URL=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
OPENAI_API_KEY=
