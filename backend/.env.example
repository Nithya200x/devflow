# DevFlow Backend — Environment Configuration
# Copy this file to .env and fill in your values.

# Server
FLASK_DEBUG=true
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database
# Set DATABASE_URL for PostgreSQL, or leave unset for SQLite (local dev)
# PostgreSQL: postgresql://user:password@host:5432/devflow
# DATABASE_URL=

# Authentication
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_EXPIRY_HOURS=24

# Initial Admin Bootstrap (used when users table is empty on startup)
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@devflow.local
# ADMIN_PASSWORD=<secure-random-password>

# Token Encryption
TOKEN_ENCRYPTION_KEY=change-this-to-a-random-encryption-key

# GitHub Integration
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Jenkins
JENKINS_URL=http://localhost:8080
JENKINS_USERNAME=admin
JENKINS_API_TOKEN=
JENKINS_JOB_NAME=devflow-pipeline
JENKINS_USER=
JENKINS_TOKEN=

# Docker
DOCKER_HUB_USERNAME=
DOCKER_HUB_TOKEN=

# Kubernetes
KUBE_CONFIG_PATH=

# Prometheus
PROMETHEUS_URL=http://127.0.0.1:30090

# Grafana
GRAFANA_URL=http://127.0.0.1:3002
GRAFANA_API_KEY=
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Alertmanager
ALERTMANAGER_URL=http://127.0.0.1:30903

# Jira
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Slack
SLACK_WEBHOOK_URL=

# SMTP
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# AI Root Cause Analysis
# Supported values: groq, openai, openai-compatible, ollama, lmstudio
AI_PROVIDER=groq
AI_TIMEOUT=120

# Groq AI (used when AI_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI / OpenAI-Compatible (used when AI_PROVIDER=openai or openai-compatible)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Ollama / Local AI (used when AI_PROVIDER=ollama or lmstudio)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
