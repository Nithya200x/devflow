# DevFlow Backend

FLASK_DEBUG=true
PORT=5000

# Authentication
JWT_SECRET_KEY=devflow-super-secret-key-change-in-prod
JWT_EXPIRY_HOURS=24

# Database
DATABASE_URL=sqlite:///../database/app.db

# Token Encryption
TOKEN_ENCRYPTION_KEY=devflow-default-enc-key

# GitHub Integration
GITHUB_TOKEN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Future Integrations (optional - leave empty until needed)
JENKINS_URL=
JENKINS_USERNAME=
JENKINS_API_TOKEN=
JENKINS_JOB_NAME=devflow-pipeline
JENKINS_USER=
JENKINS_TOKEN=
DOCKER_HUB_USERNAME=
DOCKER_HUB_TOKEN=
KUBE_CONFIG_PATH=
PROMETHEUS_URL=
GRAFANA_URL=
GRAFANA_API_KEY=
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
SLACK_WEBHOOK_URL=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
OPENAI_API_KEY=                          # Required for openai / openai-compatible providers
OPENAI_API_BASE=https://api.openai.com/v1  # Use http://localhost:1234/v1 for LM Studio
OPENAI_MODEL=gpt-4o                        # Or local model name for openai-compatible

# AI Root Cause Analysis
# Supported values: openai, openai-compatible, ollama, lmstudio, groq
AI_PROVIDER=groq
AI_TIMEOUT=120                             # Groq/Ollama: 120s, OpenAI: 60s

# Groq AI (used when AI_PROVIDER=groq)
GROQ_API_KEY=                             # Get one at https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama / Local AI (alternative to OpenAI)
# Used when AI_PROVIDER=ollama or AI_PROVIDER=lmstudio
OLLAMA_URL=http://localhost:11434          # Or http://host.docker.internal:11434 in Docker
OLLAMA_MODEL=llama3
