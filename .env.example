# DevFlow Environment Configuration
# Copy this file to .env and adjust values

# Application
APP_NAME=DevFlow SaaS
APP_VERSION=2.0.0

# Flask
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000

# Security (change in production)
JWT_SECRET_KEY=devflow-super-secret-key-change-in-prod

# Kubernetes (optional, for deployed environments)
KUBERNETES_NAMESPACE=default
KUBERNETES_NODE_NAME=localhost

# Frontend
VITE_API_URL=http://localhost:5000/api/v1
